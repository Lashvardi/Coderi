{
  "name": "koderi",
  "version": "1.0.0",
  "description": "კოდერი — კოდის რედაქტორი ბავშვებისთვის",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5200 && tsc -p tsconfig.main.json && electron .",
    "build": "tsc -p tsconfig.main.json && vite build",
    "pack": "npm run build && electron-builder",
    "dist": "npm run build && electron-builder --win"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "sharp": "^0.34.5",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.koderi.app",
    "productName": "კოდერი",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "resources/icon.png"
    ],
    "mac": {
      "icon": "resources/icon.icns",
      "category": "public.app-category.education",
      "target": ["dmg"]
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": ["nsis"]
    },
    "linux": {
      "icon": "resources/icon.png",
      "target": ["AppImage"]
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    }
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "lucide-react": "^0.400.0",
    "monaco-editor": "^0.50.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.26.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1"
  }
}
